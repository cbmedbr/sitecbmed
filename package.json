{
  "name": "meu-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "clean:cache": "rd /s /q .next 2>nul & exit 0",
    "clean": "rd /s /q .next 2>nul & rd /s /q node_modules 2>nul & npm cache clean --force",
    "reinstall": "npm run clean && npm install"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "next": "^15.3.0",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "autoprefixer": "^10.0.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1"
  }
}
